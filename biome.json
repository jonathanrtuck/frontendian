{
  "$schema": "https://biomejs.dev/schemas/1.9.4/schema.json",
  "vcs": {
    "clientKind": "git",
    "enabled": true,
    "useIgnoreFile": true
  },
  "formatter": {
    "indentStyle": "space"
  },
  "linter": {
    "rules": {
      "a11y": {
        "noAriaUnsupportedElements": "info",
        "noAutofocus": "off",
        "noInteractiveElementToNoninteractiveRole": "info",
        "useKeyWithClickEvents": "info"
      }
    }
  }
}
